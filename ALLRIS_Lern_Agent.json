        "jsCode": "function safeStr(v) { return v === null || v === undefined ? '' : String(v).trim(); }\n\nconst row = $json;\n\nreturn {\n  json: {\n    vorgangKey: safeStr(row.vorgangKey),\n    vorgangsnummer: safeStr(row.vorgangsnummer),\n    qaStage: safeStr(row.qaStage),\n    source: safeStr(row.source),\n    outcome: safeStr(row.outcome),\n    exampleSummary: safeStr(row.exampleSummary),\n    detailsJson: safeStr(row.detailsJson) || '{}',\n    createdAt: new Date().toISOString()\n  }\n};"
