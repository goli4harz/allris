                      "parameters":  {
                                         "jsCode":  "function safeStr(v) { return v === null || v === undefined ? \u0027\u0027 : String(v).trim(); }\n\nconst original = $(\u0027Execute Workflow Trigger\u0027).first().json || {};\nconst limit = Number(original.limit) \u003e 0 ? Number(original.limit) : 5;\n\nconst rows = items.map(i =\u003e i.json).filter(r =\u003e r \u0026\u0026 r.createdAt);\nrows.sort((a, b) =\u003e new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\nconst top = rows.slice(0, limit);\n\nconst examples = top.map(r =\u003e ({\n  outcome: safeStr(r.outcome),\n  exampleSummary: safeStr(r.exampleSummary),\n  detailsJson: safeStr(r.detailsJson),\n  createdAt: safeStr(r.createdAt)\n}));\n\nconst examplesText = examples.length\n  ? examples.map((e, idx) =\u003e (idx + 1) + \u0027. [\u0027 + e.outcome + \u0027] \u0027 + e.exampleSummary).join(\u0027\\n\u0027)\n  : \u0027(keine bisherigen Beispiele fuer diese Stufe)\u0027;\n\nreturn [{\n  json: {\n    qaStage: safeStr(original.qaStage),\n    count: examples.length,\n    examples,\n    examplesText\n  }\n}];"
                                     },
