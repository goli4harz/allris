    {
      "parameters": {
        "jsCode": "function safeStr(v) { return v === null || v === undefined ? '' : String(v).trim(); }\n\nconst original = $('Execute Workflow Trigger').first().json || {};\nconst limit = Number(original.limit) > 0 ? Number(original.limit) : 5;\n\nconst rows = items.map(i => i.json).filter(r => r && r.createdAt);\nrows.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());\nconst top = rows.slice(0, limit);\n\nconst examples = top.map(r => ({\n  outcome: safeStr(r.outcome),\n  exampleSummary: safeStr(r.exampleSummary),\n  detailsJson: safeStr(r.detailsJson),\n  createdAt: safeStr(r.createdAt)\n}));\n\nconst examplesText = examples.length\n  ? examples.map((e, idx) => (idx + 1) + '. [' + e.outcome + '] ' + e.exampleSummary).join('\\n')\n  : '(keine bisherigen Beispiele fuer diese Stufe)';\n\nreturn [{\n  json: {\n    qaStage: safeStr(original.qaStage),\n    count: examples.length,\n    examples,\n    examplesText\n  }\n}];"
      },
